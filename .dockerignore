# Dependencies — reinstalled inside the build stage
node_modules

# Next.js build output — produced inside the build stage
.next

# Local environment files — NEVER bake secrets into the image
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# Git metadata
.git
.gitignore

# Editor / OS metadata
.DS_Store
.idea
.vscode
*.swp
*.swo

# Test and CI artifacts
coverage
.nyc_output

# Docker files themselves (not needed inside the build context)
Dockerfile
.dockerignore

# TypeScript build info cache
tsconfig.tsbuildinfo
