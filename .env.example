# ============================================================
# DATABASE
# ============================================================
DATABASE_URI=postgresql://user:password@localhost:5432/sttpu_website
# Atau Unix socket lokal:
# DATABASE_URI=postgresql://user@%2Fvar%2Frun%2Fpostgresql/sttpu_website

# ============================================================
# BACKUP POSTGRESQL — pg_dump
# ============================================================
# ============================================================
# BACKUP POSTGRESQL — pg_dump
# ============================================================
BACKUP_DIR=./backups/postgres
BACKUP_RETENTION_DAYS=14
BACKUP_PREFIX=sttpu-postgres
BACKUP_FORMAT=custom

# ============================================================
# BACKUP UPLOAD — S3 / R2
# ============================================================
BACKUP_S3_ENABLED=false
BACKUP_S3_BUCKET=
BACKUP_S3_PREFIX=postgres
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_STORAGE_CLASS=STANDARD

# ============================================================
# PAYLOAD CMS
# ============================================================
PAYLOAD_SECRET=ganti-dengan-string-acak-panjang-di-production

# ============================================================
# SITE
# ============================================================
NEXT_PUBLIC_SITE_URL=https://www.sttpu.ac.id
NEXT_PUBLIC_DEVELOPER_PORTFOLIO_URL=https://frhn.dev
# Pilihan: glass-pill | engraved-line | marquee-soft | signature-badge
NEXT_PUBLIC_DEVELOPER_WATERMARK_STYLE=signature-badge

# ============================================================
# KONTAK CEPAT
# ============================================================
# Nomor WhatsApp tanpa + dan tanda strip (mis: 6281234567890)
NEXT_PUBLIC_WHATSAPP_NUMBER=6281234567890

# ============================================================
# MEDIA STORAGE — Cloudflare R2
# ============================================================
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=sttpu-media
S3_ENDPOINT=https://[account-id].r2.cloudflarestorage.com
S3_REGION=auto

# ============================================================
# EMAIL — Resend
# ============================================================
RESEND_API_KEY=
EMAIL_FROM=no-reply@sttpu.ac.id
EMAIL_TO=admin@sttpu.ac.id

# ============================================================
# ANALYTICS & MONITORING
# ============================================================
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ============================================================
# KEAMANAN FORM — Cloudflare Turnstile
# ============================================================
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=
