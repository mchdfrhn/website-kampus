# ============================================================
# DATABASE
# ============================================================
DATABASE_URI=postgresql://user:password@localhost:5432/sttpu_website
# Atau Unix socket lokal:
# DATABASE_URI=postgresql://user@%2Fvar%2Frun%2Fpostgresql/sttpu_website

# ============================================================
# PAYLOAD CMS
# ============================================================
PAYLOAD_SECRET=ganti-dengan-string-acak-panjang-di-production

# ============================================================
# SITE
# ============================================================
NEXT_PUBLIC_SITE_URL=https://www.sttpu.ac.id

# ============================================================
# PORTAL MAHASISWA & AKADEMIK
# ============================================================
NEXT_PUBLIC_PORTAL_SIAKAD_MHS=https://mhs.sttpu.civitas.id/
NEXT_PUBLIC_PORTAL_SIAKAD_ORTU=https://ortu.sttpu.civitas.id/
NEXT_PUBLIC_PORTAL_SIAKAD_DOSEN=https://sttsaptataruna.portaldosen.siakad.tech/

NEXT_PUBLIC_PORTAL_LMS_MHS=https://sttpu.lms.civitas.id/
NEXT_PUBLIC_PORTAL_LMS_DOSEN=https://sttpu.dosen.lms.civitas.id/

NEXT_PUBLIC_PORTAL_PMB=https://pmb.sttpu.civitas.id/
NEXT_PUBLIC_PORTAL_SIPEKAD=https://app.sipekad.web.id/

# ============================================================
# KONTAK CEPAT
# ============================================================
# Nomor WhatsApp tanpa + dan tanda strip (mis: 6281234567890)
NEXT_PUBLIC_WHATSAPP_NUMBER=6281234567890

# ============================================================
# MEDIA STORAGE — Cloudflare R2
# ============================================================
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=sttpu-media
S3_ENDPOINT=https://[account-id].r2.cloudflarestorage.com
S3_REGION=auto

# ============================================================
# EMAIL — Resend
# ============================================================
RESEND_API_KEY=
EMAIL_FROM=no-reply@sttpu.ac.id

# ============================================================
# ANALYTICS & MONITORING
# ============================================================
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ============================================================
# KEAMANAN FORM — Cloudflare Turnstile
# ============================================================
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY=
CF_TURNSTILE_SECRET_KEY=
